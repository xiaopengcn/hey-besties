<view class="page-shell">
  <nav-bar showBack="{{true}}" title="今日出门灵感"></nav-bar>

  <view wx:if="{{outfit}}" class="page-content result-content">
    <view class="page-lead">
      <text class="result-scene-pill">{{outfit.scene.name}} · {{outfit.scene.mood}}</text>
      <text class="page-lead-title">这套，很适合漂亮营业</text>
      <text class="page-lead-copy">小跳替衣柜试过了</text>
    </view>

    <view class="glass-card result-summary">
      <text class="result-label">今日主打</text>
      <text class="result-theme">{{outfit.theme.title}}</text>
      <text class="result-vibe">{{outfit.theme.vibe}}</text>
      <view wx:if="{{weatherSummary}}" class="weather-chip">
        <text class="weather-chip-label">天气小纸条</text>
        <text class="weather-chip-value">{{weatherSummary}}</text>
      </view>
      <view class="tag-row result-tags">
        <text class="tag tag--sweet">{{outfit.elements[0]}}</text>
        <text class="tag tag--warm">{{outfit.elements[1]}}</text>
        <text class="tag tag--cool">{{outfit.elements[2]}}</text>
      </view>
      <text class="result-style-summary">{{styleSummary}}</text>
      <text wx:if="{{weatherSummary}}" class="weather-summary">{{weatherSummary}}</text>
    </view>

    <view class="glass-card doll-panel">
      <view class="panel-head">
        <text class="section-title">小跳上身</text>
        <text class="panel-hint">{{outfit.look.route === 'dress' ? '连衣裙' : '上下搭'}}</text>
      </view>
      <view class="doll-tools">
        <view class="tool-orb-wrap">
          <text class="tool-orb__hint">换换</text>
          <view class="tool-orb tool-orb--warm" bindtap="reroll">
            <image class="tool-orb__icon-image" src="/assets/icons/icon-refresh.svg" mode="aspectFit"></image>
          </view>
        </view>
        <view class="tool-orb-wrap">
          <text class="tool-orb__hint">{{favorite ? '心动中' : '心动'}}</text>
          <view class="tool-orb {{favorite ? 'tool-orb--active' : ''}}" bindtap="toggleFavorite">
            <image class="tool-orb__icon-image" src="{{favorite ? '/assets/icons/icon-heart-solid.svg' : '/assets/icons/icon-heart-outline.svg'}}" mode="aspectFit"></image>
          </view>
        </view>
        <view class="tool-orb-wrap">
          <text class="tool-orb__hint">晒晒</text>
          <view class="tool-orb" bindtap="goPoster">
            <image class="tool-orb__icon-image" src="/assets/icons/icon-share.svg" mode="aspectFit"></image>
          </view>
        </view>
      </view>
      <paper-doll look="{{outfit.look}}"></paper-doll>
    </view>

    <view class="glass-card breakdown-panel">
      <text class="section-title">小心思</text>
      <view class="breakdown-list">
        <view class="breakdown-item">
          <text class="breakdown-key">今日局</text>
          <text class="breakdown-value">{{outfit.scene.name}} · {{outfit.scene.mood}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-key">氛围</text>
          <text class="breakdown-value">{{outfit.theme.title}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-key">小细节</text>
          <text class="breakdown-value">{{outfit.elements[0]}}、{{outfit.elements[1]}}、{{outfit.elements[2]}}</text>
        </view>
        <view wx:if="{{outfit.look.layers.outerwear}}" class="breakdown-item">
          <text class="breakdown-key">加分项</text>
          <text class="breakdown-value">{{outfit.look.layers.outerwear.name}}</text>
        </view>
      </view>
    </view>

    <view class="inline-actions result-actions">
      <button class="primary-button" bindtap="reroll">换一套</button>
      <button class="secondary-button" bindtap="goScenes">换个局</button>
    </view>
  </view>
</view>
