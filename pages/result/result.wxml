<view class="page-shell">
  <nav-bar showBack="{{true}}" title="今日穿搭灵感"></nav-bar>

  <view wx:if="{{outfit}}" class="page-content result-content">
    <view class="page-lead">
      <text class="result-scene-pill">{{outfit.scene.name}} · {{outfit.scene.mood}}</text>
      <text class="page-lead-title">今天这套感觉，已经帮你搭好了。</text>
      <text class="page-lead-copy">主题定方向，元素定记忆点，纸片人直接把轮廓和层次给你看明白。</text>
    </view>

    <view class="glass-card result-summary">
      <text class="result-label">今日主题</text>
      <text class="result-theme">{{outfit.theme.title}}</text>
      <text class="result-vibe">{{outfit.theme.vibe}}</text>
      <view class="tag-row result-tags">
        <text class="tag tag--sweet">{{outfit.elements[0]}}</text>
        <text class="tag tag--warm">{{outfit.elements[1]}}</text>
        <text class="tag tag--cool">{{outfit.elements[2]}}</text>
      </view>
      <text class="result-style-summary">{{styleSummary}}</text>
    </view>

    <view class="glass-card doll-panel">
      <view class="panel-head">
        <text class="section-title">纸片人上身预览</text>
        <text class="panel-hint">{{outfit.look.route === 'dress' ? '今天是连衣裙路线' : '今天是上下装路线'}}</text>
      </view>
      <view class="doll-tools">
        <button class="tool-fab tool-fab--warm" bindtap="reroll">
          <text class="tool-fab__glyph">↻</text>
        </button>
        <button class="tool-fab {{favorite ? 'tool-fab--active' : ''}}" bindtap="toggleFavorite">
          <text class="tool-fab__glyph">{{favorite ? '♥' : '♡'}}</text>
        </button>
        <button class="tool-fab" bindtap="goPoster">
          <text class="tool-fab__glyph">⇪</text>
        </button>
      </view>
      <paper-doll look="{{outfit.look}}"></paper-doll>
      <view class="doll-panel-footer">
        <text class="doll-panel-tip">右上角可以直接换一套、收藏，或者去做分享图。</text>
      </view>
    </view>

    <view class="glass-card breakdown-panel">
      <text class="section-title">为什么是这套</text>
      <view class="breakdown-list">
        <view class="breakdown-item">
          <text class="breakdown-key">场景</text>
          <text class="breakdown-value">{{outfit.scene.name}} · {{outfit.scene.mood}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-key">主线</text>
          <text class="breakdown-value">{{outfit.theme.title}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-key">执行点</text>
          <text class="breakdown-value">{{outfit.summary}}</text>
        </view>
        <view wx:if="{{outfit.look.layers.outerwear}}" class="breakdown-item">
          <text class="breakdown-key">叠穿加分</text>
          <text class="breakdown-value">{{outfit.look.layers.outerwear.name}}，让整体更有层次。</text>
        </view>
      </view>
    </view>

    <view class="inline-actions result-actions">
      <button class="primary-button" bindtap="reroll">再来一套</button>
      <button class="secondary-button" bindtap="goScenes">重选场景</button>
    </view>
  </view>
</view>
