<view class="page-shell">
  <nav-bar showBack="{{true}}" title="心动衣架"></nav-bar>

  <view class="page-content favorites-content">
    <view wx:if="{{favorites.length === 0}}" class="glass-card empty-state">
      <text class="section-title">衣架还空着</text>
      <text class="section-subtitle">遇见心动的，就把它挂在这里</text>
    </view>

    <view wx:for="{{favorites}}" wx:key="id" class="glass-card favorite-card">
      <view bindtap="openFavorite" data-id="{{item.id}}">
        <text class="favorite-scene">{{item.scene.name}}</text>
        <text class="favorite-theme">{{item.theme.title}}</text>
        <view class="tag-row favorite-tags">
          <text class="tag tag--sweet">{{item.elements[0]}}</text>
          <text class="tag tag--warm">{{item.elements[1]}}</text>
          <text class="tag tag--cool">{{item.elements[2]}}</text>
        </view>
      </view>
      <button class="secondary-button favorite-remove" data-id="{{item.id}}" bindtap="removeFavorite">取下</button>
    </view>
  </view>
</view>
