<view class="page-shell home-page">
  <nav-bar title="今天是什么局"></nav-bar>

  <view class="page-content home-content">
    <view class="page-lead">
      <text class="page-lead-title">今天出门，先给衣柜一点小灵感</text>
      <text class="page-lead-copy">挑一个局，颜色和小心机自己冒出来</text>
    </view>

    <view class="hero-card home-hero">
      <view class="hero-sun-glow"></view>
      <view class="hero-bubbles" aria-hidden="true">
        <view class="hero-bubble hero-bubble--one"></view>
        <view class="hero-bubble hero-bubble--two"></view>
        <view class="hero-bubble hero-bubble--three"></view>
      </view>
      <view class="home-hero-top">
        <view class="home-hero-left">
          <view class="sticker">OOTD</view>
          <text class="home-hero-title">{{currentScene.name}}</text>
        </view>
        <view class="weather-status weather-status--{{weatherContext.status}}">
          <text class="weather-status-title">{{weatherTitle}}</text>
          <text class="weather-status-detail">{{weatherDetail}}</text>
        </view>
      </view>
      <text class="home-hero-subtitle">{{currentScene.intro}}</text>
      <view class="hero-badges">
        <text class="hero-badge">{{currentScene.mood}}</text>
        <text class="hero-badge">{{currentScene.buttonText}}</text>
      </view>
    </view>

    <view class="glass-card scene-panel">
      <view class="scene-panel-head">
        <view>
          <text class="section-title">先定今天的局</text>
        </view>
        <text class="scene-counter">{{selectedIndexLabel}}</text>
      </view>

      <scroll-view class="scene-carousel" scroll-x="true" enhanced="true" show-scrollbar="false">
        <view
          wx:for="{{scenes}}"
          wx:key="id"
          class="scene-card {{selectedSceneId === item.id ? 'scene-card--active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onSceneTap"
        >
          <text class="scene-kicker">SCENE {{index + 1}}</text>
          <view class="scene-copy">
            <text class="scene-name">{{item.name}}</text>
            <text class="scene-mood">{{item.mood}}</text>
            <text class="scene-intro">{{item.intro}}</text>
          </view>
          <text class="scene-cta">{{item.buttonText}}</text>
        </view>
      </scroll-view>
    </view>

    <button class="primary-button generate-btn" bindtap="goGenerate">抽一套</button>
    <button class="secondary-button" bindtap="goFavorites">心动衣架</button>
  </view>
</view>
