.home-content {
  padding-top: 10rpx;
}

.home-hero {
  position: relative;
  padding: 32rpx 28rpx 36rpx;
  border-radius: 40rpx;
  overflow: hidden;
}

.mode-rail {
  display: flex;
  gap: 14rpx;
  margin: 18rpx 0 24rpx;
}

.mode-card {
  flex: 1;
  min-height: 150rpx;
  padding: 20rpx 16rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.74);
  border: 2rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 10rpx 28rpx rgba(255, 111, 145, 0.08);
}

.mode-card--active {
  background: linear-gradient(160deg, rgba(255,255,255,0.98), rgba(255,239,229,0.94));
  border-color: rgba(255,111,145,0.28);
  transform: translateY(-2rpx);
}

.mode-name,
.mode-copy,
.mode-cta {
  display: block;
}

.mode-name {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.24;
}

.mode-copy {
  margin-top: 8rpx;
  color: var(--color-ink-soft);
  font-size: 20rpx;
  line-height: 1.35;
}

.mode-cta {
  margin-top: 12rpx;
  color: var(--color-primary-deep);
  font-size: 20rpx;
  font-weight: 800;
}

.companion-strip {
  display: flex;
  gap: 14rpx;
  margin: -8rpx 0 24rpx;
}

.companion-chip {
  flex: 1;
  padding: 16rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.68);
  border: 2rpx solid rgba(255,255,255,0.86);
}

.companion-chip--active {
  background: rgba(255, 111, 145, 0.12);
  border-color: rgba(255, 111, 145, 0.24);
}

.companion-chip-title,
.companion-chip-copy {
  display: block;
}

.companion-chip-title {
  color: var(--color-ink);
  font-size: 24rpx;
  font-weight: 800;
}

.companion-chip-copy {
  margin-top: 4rpx;
  color: var(--color-ink-soft);
  font-size: 20rpx;
}

.home-hero-top,
.home-hero-subtitle,
.hero-badges {
  position: relative;
  z-index: 2;
}

.hero-sun-glow,
.hero-bubbles {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.hero-sun-glow {
  z-index: 0;
  background:
    radial-gradient(circle at 82% 24%, rgba(255,247,207,0.24) 0, rgba(255,247,207,0.08) 18%, rgba(255,247,207,0) 38%),
    radial-gradient(circle at 18% 88%, rgba(255,238,198,0.12) 0, rgba(255,238,198,0) 32%),
    linear-gradient(115deg, rgba(255,255,255,0.06) 14%, rgba(255,255,255,0) 32%, rgba(255,246,213,0.07) 56%, rgba(255,255,255,0) 72%);
  opacity: 0.82;
  animation: sunDrift 10.5s ease-in-out infinite alternate;
}

.hero-bubbles {
  z-index: 1;
}

.hero-bubble {
  position: absolute;
  border-radius: 50%;
  background:
    radial-gradient(circle at 34% 28%, rgba(255,255,255,0.22) 0, rgba(255,255,255,0.1) 18%, rgba(255,255,255,0) 42%),
    radial-gradient(circle at 72% 68%, rgba(255,177,192,0.24) 0, rgba(255,177,192,0) 58%),
    radial-gradient(circle at 24% 76%, rgba(163,231,216,0.2) 0, rgba(163,231,216,0) 54%),
    radial-gradient(circle at 76% 24%, rgba(165,214,255,0.2) 0, rgba(165,214,255,0) 52%),
    linear-gradient(145deg, rgba(255,240,226,0.2) 0%, rgba(255,255,255,0.06) 100%);
  border: 2rpx solid rgba(255,255,255,0.16);
  box-shadow: 0 8rpx 18rpx rgba(255, 183, 122, 0.08);
  transform: translate3d(0, 0, 0) scale(1);
  opacity: 0.72;
}

.hero-bubble::before {
  content: '';
  position: absolute;
  inset: 8%;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.14);
  opacity: 0.9;
}

.hero-bubble::after {
  content: '';
  position: absolute;
  top: 16%;
  left: 22%;
  width: 22%;
  height: 14%;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
  transform: rotate(-18deg);
  opacity: 0.75;
}

.hero-bubble--one {
  top: 24rpx;
  left: 20rpx;
  width: 108rpx;
  height: 108rpx;
  animation-name: bubbleOrbitOne;
  animation-duration: 17.6s;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}

.hero-bubble--two {
  top: 124rpx;
  right: 28rpx;
  width: 82rpx;
  height: 82rpx;
  opacity: 0.58;
  animation-name: bubbleOrbitTwo;
  animation-duration: 19.4s;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}

.hero-bubble--three {
  left: 232rpx;
  bottom: 18rpx;
  width: 68rpx;
  height: 68rpx;
  opacity: 0.52;
  animation-name: bubbleOrbitThree;
  animation-duration: 18.2s;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}

.home-hero-top {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.home-hero-left {
  flex: 1;
  min-width: 0;
}

.home-hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 46rpx;
  line-height: 1.14;
  font-weight: 800;
}

.home-hero-subtitle {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255,255,255,0.84);
}

.weather-status {
  flex-shrink: 0;
  max-width: 240rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.16);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  text-align: right;
  position: relative;
  z-index: 2;
}

.weather-status-title,
.weather-status-detail {
  display: block;
}

.weather-status-title {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.3;
}

.weather-status-detail {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: rgba(255,255,255,0.82);
}

.weather-status--denied,
.weather-status--failed {
  background: rgba(255,255,255,0.14);
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.hero-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
  font-size: 22rpx;
  font-weight: 700;
}

@keyframes bubbleOrbitOne {
  0% {
    transform: translate3d(0, 0, 0) scale(0.97);
  }
  22% {
    transform: translate3d(144rpx, 18rpx, 0) scale(1);
  }
  48% {
    transform: translate3d(286rpx, 98rpx, 0) scale(1.03);
  }
  74% {
    transform: translate3d(406rpx, 18rpx, 0) scale(1);
  }
  100% {
    transform: translate3d(500rpx, 62rpx, 0) scale(0.98);
  }
}

@keyframes bubbleOrbitTwo {
  0% {
    transform: translate3d(0, 0, 0) scale(0.98);
  }
  28% {
    transform: translate3d(-124rpx, -44rpx, 0) scale(1.01);
  }
  58% {
    transform: translate3d(-334rpx, 30rpx, 0) scale(0.99);
  }
  100% {
    transform: translate3d(-470rpx, 102rpx, 0) scale(1.02);
  }
}

@keyframes bubbleOrbitThree {
  0% {
    transform: translate3d(0, 0, 0) scale(0.97);
  }
  30% {
    transform: translate3d(124rpx, -86rpx, 0) scale(1);
  }
  66% {
    transform: translate3d(222rpx, -182rpx, 0) scale(1.03);
  }
  100% {
    transform: translate3d(-164rpx, -210rpx, 0) scale(0.99);
  }
}

@keyframes sunDrift {
  0% {
    transform: translate3d(-8rpx, 0, 0);
    opacity: 0.78;
  }
  100% {
    transform: translate3d(10rpx, -6rpx, 0);
    opacity: 0.96;
  }
}

.scene-panel {
  margin-top: 26rpx;
  padding: 34rpx 28rpx;
}

.scene-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.scene-counter {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 111, 145, 0.12);
  color: #b33d61;
  font-size: 22rpx;
  font-weight: 700;
}

.scene-carousel {
  margin-top: 28rpx;
  white-space: nowrap;
}

.scene-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  width: 426rpx;
  min-height: 300rpx;
  margin-right: 18rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.95) 0%, rgba(255,245,241,0.9) 100%);
  border: 2rpx solid rgba(255,255,255,0.82);
  white-space: normal;
}

.scene-card--active {
  border-color: rgba(255, 111, 145, 0.25);
  box-shadow: 0 16rpx 40rpx rgba(255, 111, 145, 0.12);
  transform: translateY(-2rpx);
}

.scene-kicker {
  display: inline-block;
  color: #b38a96;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.scene-name {
  display: block;
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.scene-mood {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #b44e6d;
  font-weight: 700;
}

.scene-intro {
  display: block;
  margin-top: 12rpx;
  color: var(--color-ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.scene-cta {
  display: inline-block;
  margin-top: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 184, 108, 0.2);
  color: #9d5d21;
  font-size: 22rpx;
  font-weight: 700;
}

.generate-btn {
  margin-top: 26rpx;
  margin-bottom: 18rpx;
}
