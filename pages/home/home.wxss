.home-content {
  padding-top: 10rpx;
}

.home-hero {
  padding: 38rpx 34rpx 42rpx;
  border-radius: 40rpx;
}

.home-hero-title {
  display: block;
  margin-top: 22rpx;
  font-size: 52rpx;
  line-height: 1.16;
  font-weight: 800;
}

.home-hero-subtitle {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255,255,255,0.84);
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.hero-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
  font-size: 22rpx;
  font-weight: 700;
}

.scene-panel {
  margin-top: 26rpx;
  padding: 34rpx 28rpx;
}

.scene-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.scene-counter {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 111, 145, 0.12);
  color: #b33d61;
  font-size: 22rpx;
  font-weight: 700;
}

.scene-carousel {
  margin-top: 28rpx;
  white-space: nowrap;
}

.scene-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  width: 426rpx;
  min-height: 300rpx;
  margin-right: 18rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.95) 0%, rgba(255,245,241,0.9) 100%);
  border: 2rpx solid rgba(255,255,255,0.82);
  white-space: normal;
}

.scene-card--active {
  border-color: rgba(255, 111, 145, 0.25);
  box-shadow: 0 16rpx 40rpx rgba(255, 111, 145, 0.12);
  transform: translateY(-2rpx);
}

.scene-kicker {
  display: inline-block;
  color: #b38a96;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.scene-name {
  display: block;
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.scene-mood {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #b44e6d;
  font-weight: 700;
}

.scene-intro {
  display: block;
  margin-top: 12rpx;
  color: var(--color-ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.scene-cta {
  display: inline-block;
  margin-top: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 184, 108, 0.2);
  color: #9d5d21;
  font-size: 22rpx;
  font-weight: 700;
}

.generate-btn {
  margin-top: 26rpx;
  margin-bottom: 18rpx;
}
