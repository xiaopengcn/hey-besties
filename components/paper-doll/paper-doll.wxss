.paper-stage {
  position: relative;
  width: 100%;
  height: 760rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.paper-aura {
  position: absolute;
  top: 86rpx;
  width: 396rpx;
  height: 508rpx;
  border-radius: 44% 44% 36% 36%;
  background: radial-gradient(circle at 50% 30%, rgba(255, 212, 108, 0.24) 0%, rgba(255, 139, 172, 0.16) 42%, rgba(255, 255, 255, 0) 76%);
  filter: blur(16rpx);
}

.paper-stand {
  position: absolute;
  bottom: 54rpx;
  width: 372rpx;
  height: 126rpx;
  border-radius: 38rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.7) 0%, rgba(255, 241, 234, 0.92) 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255,255,255,0.88),
    0 16rpx 42rpx rgba(255, 111, 145, 0.14);
}

.paper-shadow {
  position: absolute;
  bottom: 78rpx;
  width: 320rpx;
  height: 72rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse, rgba(255, 143, 171, 0.28) 0%, rgba(255, 143, 171, 0) 72%);
}

/* Floating decorations */
.deco {
  position: absolute;
  z-index: 0;
  animation: floatDeco 5s ease-in-out infinite;
  pointer-events: none;
}

.deco-heart-a {
  left: 24rpx;
  top: 160rpx;
  font-size: 32rpx;
  color: #ff8cab;
  opacity: 0.7;
  animation-delay: 0s;
}

.deco-heart-b {
  right: 20rpx;
  top: 280rpx;
  font-size: 26rpx;
  color: #ffb8c6;
  opacity: 0.65;
  animation-delay: 1.2s;
}

.deco-star-a {
  left: 52rpx;
  top: 310rpx;
  font-size: 28rpx;
  color: #ffc77c;
  opacity: 0.7;
  animation-delay: 0.6s;
}

.deco-star-b {
  right: 44rpx;
  top: 140rpx;
  font-size: 24rpx;
  color: #ffe291;
  opacity: 0.72;
  animation-delay: 1.8s;
}

.deco-star-c {
  left: 38rpx;
  top: 420rpx;
  font-size: 22rpx;
  color: #ffc77c;
  opacity: 0.6;
  animation-delay: 2.4s;
}

.deco-sparkle-a {
  right: 32rpx;
  top: 400rpx;
  font-size: 24rpx;
  color: #c3a6ff;
  opacity: 0.55;
  animation-delay: 0.8s;
}

.deco-sparkle-b {
  left: 64rpx;
  top: 240rpx;
  font-size: 20rpx;
  color: #8fcfff;
  opacity: 0.6;
  animation-delay: 2.0s;
}

@keyframes floatDeco {
  0%, 100% {
    transform: translateY(0) scale(1);
  }
  50% {
    transform: translateY(-14rpx) scale(1.08);
  }
}

.paper-doll {
  position: relative;
  width: 360rpx;
  height: 640rpx;
  animation: floaty 4.6s ease-in-out infinite;
}

.hair-back,
.body-head,
.face,
.hair,
.fringe,
.body-neck,
.body-torso,
.body-arm,
.body-leg,
.body-shoe,
.garment,
.accessory {
