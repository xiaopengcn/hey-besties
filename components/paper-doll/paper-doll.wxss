.palette-cream::before,
.palette-rose::before,
.palette-peach::before,
.palette-caramel::before,
.palette-mint::before,
.palette-sky::before,
.palette-coral::before,
.palette-butter::before,
.palette-fog::before,
.palette-oat::before,
.palette-denim::before,
.palette-matcha::before,
.palette-tea::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.22) 0%, rgba(255,255,255,0) 45%, rgba(0,0,0,0.08) 100%);
  pointer-events: none;
}

.mat-linen {
  background-image:
    repeating-linear-gradient(90deg, rgba(255,255,255,0.18) 0 4rpx, rgba(0,0,0,0) 4rpx 12rpx),
    url('/assets/textures/linen-tile.png');
  background-size: auto, 128rpx 128rpx;
}

.mat-denim {
  background-image:
    linear-gradient(180deg, rgba(255,255,255,0.12) 0%, rgba(0,0,0,0.08) 100%),
    url('/assets/textures/denim-tile.png');
  background-size: auto, 128rpx 128rpx;
}

.mat-cotton {
  box-shadow: inset 0 0 0 4rpx rgba(255,255,255,0.28);
}

.mat-knit {
  background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.18) 0 6rpx, rgba(0,0,0,0) 6rpx 14rpx);
}

.mat-chiffon {
  opacity: 0.92;
}

.mat-satin {
  background-image: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.06) 40%, rgba(255,255,255,0.26) 100%);
}

.linen-grid::after,
.denim-diagonal::after,
.cotton-soft::after,
.knit-rib::after,
.chiffon-sheer::after,
.satin-shine::after {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.linen-grid::after {
  background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.12) 0 3rpx, transparent 3rpx 12rpx);
}

.denim-diagonal::after {
  background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.08) 0 6rpx, transparent 6rpx 14rpx);
}

.cotton-soft::after {
  background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.18) 0%, transparent 40%);
}

.knit-rib::after {
  background-image: repeating-linear-gradient(90deg, rgba(255,255,255,0.12) 0 4rpx, transparent 4rpx 12rpx);
}

.chiffon-sheer::after {
  background: linear-gradient(180deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.06) 56%, transparent 100%);
}

.satin-shine::after {
  background: linear-gradient(120deg, rgba(255,255,255,0.36) 8%, rgba(255,255,255,0) 30%, rgba(255,255,255,0.28) 62%, rgba(255,255,255,0) 88%);
}

