.nav-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  padding-left: 28rpx;
  padding-right: 28rpx;
  background: linear-gradient(180deg, rgba(255, 250, 247, 0.96) 0%, rgba(255, 245, 241, 0.88) 74%, rgba(255, 245, 241, 0) 100%);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.nav-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

/* Glass back button */
.glass-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 20rpx rgba(255, 111, 145, 0.12);
}
.glass-back:active {
  background: rgba(255, 200, 210, 0.3);
  border-color: rgba(255, 111, 145, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(255, 111, 145, 0.08);
  transform: scale(0.94);
}

.nav-back-icon {
  font-size: 42rpx;
  line-height: 1;
  color: #7d5e69;
  font-weight: 300;
  transform: translateY(-2rpx);
}

.nav-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 800;
  color: #2f1f28;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-spacer {
  flex-shrink: 0;
  margin-left: auto;
}
