.bestie-stage {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.stage-info-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.stage-count-chip {
  flex-shrink: 0;
}

.share-chiclet {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 24rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border: 0;
  box-shadow: 0 10rpx 22rpx rgba(255, 111, 145, 0.18);
  line-height: 1;
}

.share-chiclet-icon {
  width: 28rpx;
  height: 28rpx;
}

.share-chiclet-text {
  color: #fff;
}

.stage-shell {
  position: relative;
  min-height: 860rpx;
  padding: 34rpx 16rpx 24rpx;
  overflow: hidden;
}

.stage-glow,
.stage-floor {
  position: absolute;
  pointer-events: none;
}

.stage-glow {
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  filter: blur(20rpx);
  opacity: 0.72;
}

.stage-glow--left {
  left: -20rpx;
  top: 160rpx;
  background: rgba(255, 184, 108, 0.22);
}

.stage-glow--right {
  right: -30rpx;
  top: 100rpx;
  background: rgba(143, 207, 255, 0.2);
}

.stage-floor {
  left: 50%;
  bottom: 40rpx;
  width: 520rpx;
  height: 150rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  background:
    radial-gradient(ellipse at center, rgba(255, 177, 150, 0.16) 0%, rgba(255, 177, 150, 0.02) 56%, rgba(255, 177, 150, 0) 72%),
    radial-gradient(ellipse at center, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0) 70%);
}

.stage-ring {
  position: relative;
  height: 800rpx;
}

.stage-slot {
  position: absolute;
  top: 50%;
  width: 250rpx;
  height: 620rpx;
  transform-origin: center center;
  will-change: transform, opacity, filter;
  transition:
    transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 320ms ease,
    filter 420ms cubic-bezier(0.22, 1, 0.36, 1);
}

.stage-slot--left {
  left: 10rpx;
  transform: translateY(-47%) scale(0.78);
  opacity: 0.82;
  filter: saturate(0.92);
  z-index: 1;
}

.stage-slot--center {
  left: 50%;
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
  z-index: 3;
}

.stage-slot--right {
  right: 10rpx;
  transform: translateY(-47%) scale(0.78);
  opacity: 0.82;
  filter: saturate(0.92);
  z-index: 1;
}

.stage-slot--active {
  z-index: 4;
}

.stage-slot--placeholder {
  opacity: 0.72;
}

.stage-doll-wrap,
.stage-slot-empty {
  position: relative;
  width: 100%;
  height: 100%;
}

.stage-doll-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.stage-slot .paper-stage {
  transform: scale(0.8);
  transform-origin: center center;
  transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1), opacity 320ms ease;
  opacity: 0.96;
}

.stage-slot--center .paper-stage {
  transform: scale(1);
  opacity: 1;
}

.doll-identity-row {
  position: absolute;
  left: 18rpx;
  top: 10rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 5;
}

.doll-name-pill {
  padding: 10rpx 20rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 184, 108, 0.22);
  color: #935117;
  font-size: 24rpx;
  font-weight: 700;
}

.doll-me-tag {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 111, 145, 0.16);
  color: var(--color-primary-deep);
  font-size: 20rpx;
  font-weight: 700;
}

.copy-orb-wrap {
  position: absolute;
  top: 300rpx;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1), opacity 320ms ease;
}

.copy-orb-wrap--left {
  right: 16rpx;
  transform: scale(0.92);
}

.copy-orb-wrap--center {
  left: 8rpx;
  transform: scale(1);
}

.copy-orb-wrap--right {
  left: 16rpx;
  transform: scale(0.92);
}

.copy-orb {
  position: relative;
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 72rpx;
  min-height: 72rpx;
  max-height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,246,242,0.98) 100%);
  box-shadow:
    0 10rpx 26rpx rgba(255, 111, 145, 0.12),
    inset 0 2rpx 0 rgba(255,255,255,0.96);
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy-orb::before {
  content: '';
  position: absolute;
  inset: 1rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.88);
}

.copy-orb--warm {
  background: linear-gradient(180deg, rgba(255,250,243,0.98) 0%, rgba(255,237,225,0.98) 100%);
}

.copy-orb__icon-image {
  position: relative;
  z-index: 1;
  width: 32rpx;
  height: 32rpx;
}

.stage-slot-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 0 18rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.36) 0%, rgba(255,255,255,0.14) 100%);
  border: 2rpx dashed rgba(255, 184, 108, 0.3);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.42);
}

.stage-slot-empty-icon {
  font-size: 64rpx;
  color: var(--color-primary);
  opacity: 0.46;
}

.stage-slot-empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-ink-soft);
}

.stage-slot-empty-copy {
  font-size: 24rpx;
  color: var(--color-ink-faint);
  max-width: 180rpx;
  text-align: center;
  line-height: 1.6;
}

.active-outfit-card {
  padding: 28rpx;
}

.stage-tags {
  margin-top: 18rpx;
}

.dev-actions {
  display: flex;
  justify-content: center;
  padding-top: 8rpx;
}

.dev-actions .secondary-button {
  flex: none;
  width: auto;
  padding: 0 40rpx;
  min-height: 80rpx;
  font-size: 26rpx;
  border: 2rpx dashed rgba(255, 184, 108, 0.4);
  background: rgba(255, 255, 255, 0.6);
  color: var(--color-ink-soft);
}
