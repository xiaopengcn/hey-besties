<view class="bestie-stage">
  <view class="stage-info-bar">
    <text class="pill-chip stage-count-chip">{{participants.length}}/3 闺蜜在线</text>
    <button class="share-chiclet" open-type="share">
      <image class="share-chiclet-icon" src="/assets/icons/icon-share.svg" mode="aspectFit"></image>
      <text class="share-chiclet-text">邀请闺蜜</text>
    </button>
  </view>

  <view
    class="stage-shell glass-card"
    bindtouchstart="onStageTouchStart"
    bindtouchend="onStageTouchEnd"
  >
    <view class="stage-glow stage-glow--left"></view>
    <view class="stage-glow stage-glow--right"></view>
    <view class="stage-floor"></view>

    <view class="stage-ring">
      <view
        wx:for="{{stageSlots}}"
        wx:key="slotKey"
        class="stage-slot stage-slot--{{item.position}} {{item.isPlaceholder ? 'stage-slot--placeholder' : ''}} {{item.isActive ? 'stage-slot--active' : ''}}"
        data-index="{{item.targetIndex}}"
        bindtap="onSlotTap"
      >
        <view wx:if="{{item.isPlaceholder}}" class="stage-slot-empty">
          <text class="stage-slot-empty-icon">✧</text>
          <text class="stage-slot-empty-title">等闺蜜入场</text>
          <text class="stage-slot-empty-copy">分享一下，舞台就会热闹起来</text>
        </view>

        <view wx:else class="stage-doll-wrap">
          <view class="doll-identity-row">
            <text class="doll-name-pill">{{item.participant.nickName}}</text>
            <text wx:if="{{item.participant.userId === myUserId}}" class="doll-me-tag">我</text>
          </view>

          <view
            wx:if="{{item.participant.userId !== myUserId}}"
            class="copy-orb-wrap copy-orb-wrap--{{item.position}}"
            data-index="{{item.targetIndex}}"
            bindtap="onCopyTap"
          >
            <view class="copy-orb copy-orb--warm">
              <image class="copy-orb__icon-image" src="/assets/icons/icon-hand.svg" mode="aspectFit"></image>
            </view>
          </view>

          <paper-doll
            look="{{item.participant.outfit.look}}"
            companion="{{item.participant.outfit.companion}}"
            companionOutfit="{{item.participant.outfit.companionOutfit}}"
          ></paper-doll>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{activeParticipant}}" class="active-outfit-card glass-card">
    <text class="section-title">{{activeParticipant.outfit.theme.title}}</text>
    <view class="tag-row stage-tags">
      <text class="tag tag--sweet">{{activeParticipant.outfit.elements[0]}}</text>
      <text class="tag tag--warm">{{activeParticipant.outfit.elements[1]}}</text>
      <text class="tag tag--cool">{{activeParticipant.outfit.elements[2]}}</text>
    </view>
  </view>

  <view wx:if="{{isDevMode && participants.length < 3}}" class="dev-actions">
    <button class="secondary-button" bindtap="onAddMockTap">加个闺蜜</button>
  </view>
</view>
